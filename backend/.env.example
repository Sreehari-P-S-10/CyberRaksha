# CyberRaksha Backend — Environment Variables
# Copy this file to .env and fill in the values

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # change to 'production' on Render

# ── Database ─────────────────────────────────────────────
# Local Postgres (dev):
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/cyberraksha

# Neon (production — paste the connection string from your Neon project dashboard):
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/cyberraksha?sslmode=require

# ── Auth ─────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# ── CORS ─────────────────────────────────────────────────
# Dev — Vite dev server:
CLIENT_URL=http://localhost:5173

# Production — your Vercel URL:
# CLIENT_URL=https://cyberraksha.vercel.app
